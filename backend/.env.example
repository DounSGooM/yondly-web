# ─── Database ───────────────────────────────────────────────
MONGO_URL=mongodb+srv://<user>:<password>@cluster0.xxxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=yondly_db

# ─── Auth ────────────────────────────────────────────────────
JWT_SECRET=change_me_in_production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=720
ADMIN_KEY=change_me_in_production

# ─── Stripe ──────────────────────────────────────────────────
STRIPE_PUBLIC_KEY=pk_live_xxx
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx

# ─── Cloudinary ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Email (SMTP) ────────────────────────────────────────────
SMTP_HOST=mail.infomaniak.com
SMTP_PORT=587
SMTP_USER=no-reply@yondly.com
SMTP_PASSWORD=your_smtp_password
SENDER_EMAIL=no-reply@yondly.com
SENDER_NAME=L'équipe Yondly

# ─── Brevo ───────────────────────────────────────────────────
BREVO_API_KEY=your_brevo_key

# ─── Google AI ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_key
GOOGLE_CLOUD_VISION_API_KEY=your_vision_key

# ─── INSEE ───────────────────────────────────────────────────
INSEE_API_TOKEN=your_insee_token

# ─── CORS (ajouter l'URL Railway ici après déploiement) ──────
ALLOWED_ORIGINS=https://your-app.up.railway.app

# ─── Port (géré automatiquement par Railway) ─────────────────
# PORT=8000
