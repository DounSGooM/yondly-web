{
    "version": 2,
    "builds": [
        {
            "src": "website-yondly/frontend/package.json",
            "use": "@vercel/static-build",
            "config": {
                "distDir": "build"
            }
        },
        {
            "src": "backend/api/index.py",
            "use": "@vercel/python"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "/backend/api/index.py"
        },
        {
            "src": "/(.*)",
            "dest": "/website-yondly/frontend/$1"
        }
    ]
}