{
    "cli": {
        "version": ">= 5.9.1",
        "appVersionSource": "remote"
    },
    "build": {
        "development": {
            "developmentClient": true,
            "distribution": "internal",
            "ios": {
                "simulator": false
            }
        },
        "preview": {
            "distribution": "internal",
            "android": {
                "buildType": "apk"
            },
            "ios": {
                "simulator": false
            },
            "env": {
                "EXPO_PUBLIC_API_URL": "https://yondly-backend-951855414282.europe-west1.run.app/api",
                "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
            }
        },
        "production": {
            "autoIncrement": true,
            "node": "20.19.0",
            "env": {
                "NPM_CONFIG_LEGACY_PEER_DEPS": "true"
            }
        }
    },
    "submit": {
        "production": {}
    }
}
